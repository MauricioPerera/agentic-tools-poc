{
  "name": "agentic-tools-poc",
  "version": "0.1.0",
  "description": "POC: GitHub-stored TS tools + just-bash runtime + jsDelivr distribution",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "pretest": "node scripts/build.ts && node scripts/manifest.ts",
    "test": "node --test --test-reporter=spec test/*.test.ts",
    "validate": "node scripts/validate.ts",
    "lint": "node scripts/lint.ts",
    "codegen": "node scripts/codegen-types.ts",
    "codegen:check": "node scripts/codegen-types.ts --check",
    "smoke": "node scripts/smoke-test-skills.ts",
    "build": "node scripts/build.ts",
    "manifest": "node scripts/manifest.ts",
    "all": "npm run typecheck && npm run test && npm run validate && npm run lint && npm run codegen:check && npm run build && npm run manifest",
    "demo": "node client/demo.ts",
    "mcp:server": "node client/mcp-server.ts",
    "mcp:classic": "node client/mcp-server-classic.ts",
    "agent:granite": "node client/agent-granite.ts",
    "compare": "node client/compare.ts",
    "exec": "node client/exec-bash.ts",
    "discover": "node client/load-domain.ts"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "esbuild": "^0.24.0",
    "typescript": "^6.0.3",
    "yaml": "^2.6.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "just-bash": "^2.14.2",
    "quickjs-emscripten": "^0.32.0"
  }
}
