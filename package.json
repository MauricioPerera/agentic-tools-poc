{
  "name": "agentic-tools-poc",
  "version": "0.1.0",
  "description": "POC: GitHub-stored TS tools + just-bash runtime + jsDelivr distribution",
  "type": "module",
  "private": true,
  "engines": { "node": ">=22" },
  "scripts": {
    "test": "node --test --test-reporter=spec test/*.test.mjs",
    "validate": "node scripts/validate.mjs",
    "build": "node scripts/build.mjs",
    "manifest": "node scripts/manifest.mjs",
    "all": "npm run test && npm run validate && npm run build && npm run manifest",
    "demo": "node client/demo.mjs",
    "mcp:server": "node client/mcp-server.mjs",
    "mcp:test": "node client/test-mcp.mjs",
    "mcp:classic": "node client/mcp-server-classic.mjs",
    "mcp:classic:test": "node client/test-mcp-classic.mjs",
    "agent:granite": "node client/agent-granite.mjs",
    "compare": "node client/compare.mjs",
    "exec": "node client/exec-bash.mjs",
    "discover": "node client/load-domain.mjs"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "yaml": "^2.6.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "just-bash": "^2.14.2"
  }
}
